# Trakt API app credentials — create an app at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
# Must exactly match the redirect URI configured on the Trakt app, e.g.
# https://your-deployment.vercel.app/api/trakt/callback
TRAKT_REDIRECT_URI=

# Supabase project — Settings > API
SUPABASE_URL=
# Service role key (server-only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Any long random string. Sent as the x-api-key header by callers (e.g. a
# ChatGPT Custom GPT Action) of /api/trakt/recommendation-context.
RECOMMENDATION_API_KEY=
